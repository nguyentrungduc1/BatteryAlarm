<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔋 Battery Alarm"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#3A1078"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Theo dõi pin &amp; cảnh báo tự động"
            android:textSize="14sp"
            android:textColor="#888"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <!-- Battery Status Card -->
        <androidx.cardview.widget.CardView
            xmlns:card="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card:cardCornerRadius="16dp"
            card:cardElevation="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#7B2FBE">

                <TextView
                    android:id="@+id/tv_battery_level"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center" />

                <ProgressBar
                    android:id="@+id/battery_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#A8FF78"
                    android:progressBackgroundTint="#FFFFFF40"
                    android:layout_marginVertical="12dp" />

                <TextView
                    android:id="@+id/tv_charging"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đang tải..."
                    android:textSize="16sp"
                    android:textColor="#FFE082"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tv_temp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nhiệt độ: --"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tv_voltage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Điện áp: --"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:gravity="center" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Settings Card -->
        <androidx.cardview.widget.CardView
            xmlns:card="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card:cardCornerRadius="16dp"
            card:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Cài đặt ngưỡng cảnh báo"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3A1078"
                    android:paddingBottom="16dp" />

                <!-- Low Alarm Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔴 Cảnh báo pin thấp (%)"
                        android:textSize="14sp"
                        android:textColor="#333" />

                    <EditText
                        android:id="@+id/et_low_threshold"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="20"
                        android:gravity="center"
                        android:background="@drawable/input_bg"
                        android:padding="8dp"
                        android:textSize="16sp"
                        android:textColor="#3A1078"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Low Alarm Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bật cảnh báo pin thấp"
                        android:textSize="14sp"
                        android:textColor="#555" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_low_alarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="16dp" />

                <!-- Full Alarm Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🟢 Cảnh báo pin đầy (%)"
                        android:textSize="14sp"
                        android:textColor="#333" />

                    <EditText
                        android:id="@+id/et_full_threshold"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="90"
                        android:gravity="center"
                        android:background="@drawable/input_bg"
                        android:padding="8dp"
                        android:textSize="16sp"
                        android:textColor="#3A1078"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Full Alarm Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bật cảnh báo pin đầy"
                        android:textSize="14sp"
                        android:textColor="#555" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_full_alarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Do Not Disturb Card -->
        <androidx.cardview.widget.CardView
            xmlns:card="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card:cardCornerRadius="16dp"
            card:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <!-- Header row with switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔕 Không làm phiền"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#3A1078" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_dnd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tắt âm thanh cảnh báo trong khoảng thời gian:"
                    android:textSize="13sp"
                    android:textColor="#666"
                    android:paddingBottom="12dp" />

                <!-- Time range row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Từ"
                        android:textSize="14sp"
                        android:textColor="#333"
                        android:layout_marginEnd="8dp" />

                    <EditText
                        android:id="@+id/et_dnd_start"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="22"
                        android:gravity="center"
                        android:background="@drawable/input_bg"
                        android:padding="8dp"
                        android:textSize="16sp"
                        android:textColor="#3A1078"
                        android:textStyle="bold"
                        android:maxLength="2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="giờ  đến"
                        android:textSize="14sp"
                        android:textColor="#333"
                        android:layout_marginHorizontal="8dp" />

                    <EditText
                        android:id="@+id/et_dnd_end"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="6"
                        android:gravity="center"
                        android:background="@drawable/input_bg"
                        android:padding="8dp"
                        android:textSize="16sp"
                        android:textColor="#3A1078"
                        android:textStyle="bold"
                        android:maxLength="2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="giờ"
                        android:textSize="14sp"
                        android:textColor="#333"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="* Nhập theo định dạng 24h (0–23). Ví dụ: 22 đến 6."
                    android:textSize="12sp"
                    android:textColor="#999"
                    android:paddingTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾 LƯU CÀI ĐẶT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B2FBE"
            android:layout_marginBottom="16dp" />

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            xmlns:card="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card:cardCornerRadius="12dp"
            card:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFF9C4">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ Thông tin"
                    android:textStyle="bold"
                    android:textColor="#F57F17"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Ứng dụng chạy nền liên tục\n• Cảnh báo bằng giọng nữ tiếng Việt\n• Nhắc lại sau 10 phút nếu chưa xử lý\n• Tự khởi động sau khi tắt máy"
                    android:textColor="#5D4037"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
